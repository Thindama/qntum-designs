# ═══════════════════════════════════════
# Qntum Designs — Environment Variables
# ═══════════════════════════════════════
# Kopiere diese Datei zu .env und fülle die Werte aus:
#   cp .env.example .env

# ── Anthropic (Claude API) ─────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Supabase ───────────────────────────
SUPABASE_URL=https://dein-projekt.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ── Server ─────────────────────────────
PORT=3000
SESSION_SECRET=ein-langer-zufaelliger-string-hier
NODE_ENV=development
APP_DOMAIN=deine-app.railway.app

# ── Stripe (optional, für Bezahlung) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_BIZ_MONTHLY=price_...
STRIPE_PRICE_BIZ_YEARLY=price_...
